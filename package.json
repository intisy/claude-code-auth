{
  "name": "claude-code-auth",
  "version": "2.2.0",
  "description": "Claude Code subscription auth provider for OpenCode and Claude Code — multiple Claude accounts via OAuth, with subscription rate limits exposed to OpenCode.",
  "main": "dist/index.js",
  "type": "module",
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy-ai/claude-code-auth.git"
  },
  "keywords": [
    "opencode",
    "claude",
    "claude-code",
    "anthropic",
    "oauth",
    "subscription",
    "provider",
    "auth"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "claude-code-auth": "dist/cli.js"
  },
  "claudeHub": {
    "authProviders": [
      {
        "name": "claude-code",
        "handler": "dist/handler.js",
        "models": [
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6 (Claude Code)"
          },
          {
            "id": "claude-opus-4-6-thinking",
            "name": "Claude Opus 4.6 Thinking (Claude Code)"
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6 (Claude Code)"
          },
          {
            "id": "claude-sonnet-4-6-thinking",
            "name": "Claude Sonnet 4.6 Thinking (Claude Code)"
          },
          {
            "id": "claude-haiku-4-5",
            "name": "Claude Haiku 4.5 (Claude Code)"
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "npx tsc --project core-auth/tsconfig.json && node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@openauthjs/openauth": "^0.4.3",
    "@opencode-ai/plugin": "^0.15.30",
    "proper-lockfile": "^4.1.2",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.25.12",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
